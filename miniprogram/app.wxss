page {
  min-height: 100%;
  background: #f7f5f1;
  color: #172238;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(23, 34, 56, 0.08);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 36rpx rgba(23, 34, 56, 0.08);
}

.muted {
  color: #687083;
}

.primary-button {
  height: 88rpx;
  border-radius: 16rpx;
  background: #ff6b45;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 88rpx;
}

.secondary-button {
  height: 88rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid rgba(23, 34, 56, 0.16);
  color: #172238;
  font-size: 30rpx;
  line-height: 88rpx;
}

.danger-button {
  height: 88rpx;
  border-radius: 16rpx;
  background: #fff2ef;
  color: #c63f20;
  font-size: 30rpx;
  line-height: 88rpx;
}
