.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: #687083;
  font-size: 24rpx;
}

.mini-button {
  width: 132rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: #172238;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 64rpx;
  flex: none;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.activity-card {
  overflow: hidden;
}

.cover {
  width: 100%;
  height: 260rpx;
  display: block;
  background: #e9e5de;
}

.content {
  padding: 24rpx;
}

.row,
.footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.category {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e9fbf8;
  color: #128577;
  font-size: 22rpx;
}

.status {
  color: #687083;
  font-size: 22rpx;
}

.activity-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.summary {
  margin-top: 10rpx;
  color: #687083;
  font-size: 26rpx;
  line-height: 1.5;
}

.meta {
  margin-top: 10rpx;
  color: #4e5768;
  font-size: 24rpx;
}

.footer {
  margin-top: 18rpx;
  color: #687083;
  font-size: 24rpx;
}

.price {
  color: #ff6b45;
  font-weight: 700;
}

.empty {
  padding: 40rpx 28rpx;
  color: #687083;
  text-align: center;
}
