.login-page {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 8rpx 8rpx;
}

.logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #ff6b45;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 700;
  text-align: center;
  line-height: 96rpx;
}

.title {
  font-size: 46rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 8rpx;
  color: #687083;
  font-size: 26rpx;
}

.login-card {
  padding: 30rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #687083;
  font-size: 24rpx;
}

input {
  height: 86rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #f7f5f1;
  font-size: 30rpx;
  box-sizing: border-box;
}

.demo-button {
  margin-top: 20rpx;
}

.notice {
  color: #687083;
  font-size: 24rpx;
  line-height: 1.6;
}
