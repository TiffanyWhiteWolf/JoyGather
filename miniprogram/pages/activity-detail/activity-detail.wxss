.detail-page {
  padding-bottom: 180rpx;
}

.cover {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  display: block;
  margin-bottom: 22rpx;
  background: #e9e5de;
}

.detail-card {
  padding: 26rpx;
  margin-bottom: 22rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.category {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e9fbf8;
  color: #128577;
  font-size: 22rpx;
}

.status {
  color: #687083;
  font-size: 22rpx;
}

.title {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.summary,
.description {
  margin-top: 14rpx;
  color: #4e5768;
  font-size: 28rpx;
  line-height: 1.65;
}

.facts {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.fact {
  display: flex;
  gap: 20rpx;
  font-size: 26rpx;
}

.label {
  width: 84rpx;
  color: #687083;
  flex: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.organizer {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  font-size: 28rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #e9e5de;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx 34rpx;
  background: #ffffff;
  box-shadow: 0 -10rpx 32rpx rgba(23, 34, 56, 0.08);
  box-sizing: border-box;
}

.current-status {
  margin-bottom: 12rpx;
  color: #687083;
  font-size: 24rpx;
  text-align: center;
}

.empty {
  padding: 40rpx 28rpx;
  color: #687083;
  text-align: center;
}
